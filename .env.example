# GEMINI_API_KEY: Required for Vercel Serverless Function (/api/analyze).
# Get your API key from https://aistudio.google.com/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# Comma-separated allowlist for CORS (recommended in production).
# Example: ALLOWED_ORIGINS="https://hachi-dev.codes,https://www.hachi-dev.codes,http://localhost:3000"
ALLOWED_ORIGINS="https://hachi-dev.codes,https://www.hachi-dev.codes,http://localhost:3000"

# Optional: set when frontend and API are on different domains.
# Example: VITE_API_BASE_URL="https://your-vercel-project.vercel.app"
VITE_API_BASE_URL=""

# Server Port (not used for GitHub Pages deployment)
PORT=3001

