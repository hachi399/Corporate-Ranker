# VITE_GEMINI_API_KEY: Required for Gemini AI API calls in client-side code.
# For local development: Get your API key from https://aistudio.google.com/apikey
# For GitHub Pages deployment: This will be set via GitHub Secrets in the build workflow.
# ⚠️ SECURITY WARNING: This key will be embedded in the client-side code and visible to users!
VITE_GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# Server Port (not used for GitHub Pages deployment)
PORT=3001

